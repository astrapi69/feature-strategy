{
  "name": "@astrapi69/feature-strategy-react",
  "version": "0.1.0",
  "description": "React adapter for @astrapi69/feature-strategy: provider, useFeature hook and Feature component",
  "keywords": [
    "feature-flags",
    "feature-gating",
    "authorization",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "author": "Asterios Raptis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrapi69/feature-strategy.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrapi69/feature-strategy": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
