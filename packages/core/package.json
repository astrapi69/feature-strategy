{
  "name": "@astrapi69/feature-strategy",
  "version": "0.1.0",
  "description": "Framework-agnostic feature gating and component authorization strategies with three states: active, disabled, hidden",
  "keywords": [
    "feature-flags",
    "feature-gating",
    "authorization",
    "strategy",
    "typescript"
  ],
  "license": "MIT",
  "author": "Asterios Raptis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrapi69/feature-strategy.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
